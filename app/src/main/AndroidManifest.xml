<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    /
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="SAWeather"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar"
        tools:targetApi="31">

        <!-- Login Activity (Main Launcher) -->
        <activity
            android:name="com.example.saweather.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Weather Detail Activity -->
        <activity
            android:name="com.example.saweather.WeatherDetailActivity"
            android:exported="false" />

        <!-- Locations Activity -->
        <activity
            android:name="com.example.saweather.LocationsActivity"
            android:exported="false" />

        <!-- Forecast Activity -->
        <activity
            android:name="com.example.saweather.ForecastActivity"
            android:exported="false" />

        <!-- Air Quality Activity -->
        <activity
            android:name="com.example.saweather.AirQualityActivity"
            android:exported="false" />

    </application>

</manifest>